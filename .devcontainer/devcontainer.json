{
    "name": "JIDE PHP Apache Workspace",
    "build": {
      "dockerfile": "Dockerfile"
    },
    "workspaceFolder": "/var/www/html",
    "forwardPorts": [80, 5500],
    "postCreateCommand": "service apache2 start && chmod +x .devcontainer/post-create.sh && ./.devcontainer/post-create.sh",
    "customizations": {
      "vscode": {
        "extensions": [
          "felixfbecker.php-debug",
          "xdebug.php-pack",
          "zhuangtongfa.material-theme",
          "vscode-icons-team.vscode-icons",
          "ritwickdey.live-sass",
          "christian-kohler.path-intellisense",
          "github.vscode-pull-request-github",
          "yandeu.five-server"
        ],
        "settings": {
          "php.validate.executablePath": "/usr/bin/php",
          "php.debug.executablePath": "/usr/bin/php",
          "workbench.colorTheme": "One Dark Pro",
          "editor.cursorBlinking": "smooth",
          "editor.cursorSmoothCaretAnimation": "on",
          "editor.mouseWheelZoom": true,
          "window.menuBarVisibility": "toggle",
          "workbench.sideBar.location": "left",
          "fiveServer.php.executable": "/usr/bin/php",
          "editor.smoothScrolling": true,
          "git.path": "/usr/bin/git"
        }
      }
    },
    "features": {
      "gh-cli": "latest"
    }
  }
  